<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_MarsColony_FEFO" targetNamespace="https://github.com/CyZeTLC/Mars-Colony-Project/bpmn/fefo-risk-inventory" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <bpmn:collaboration id="Collaboration_MarsColony_FEFO">
    <bpmn:participant id="Participant_MarsColony" name="Mars Colony - Lager- und Ressourcenmanagement" processRef="Process_FEFO_RiskInventory" />
  </bpmn:collaboration>
  <bpmn:process id="Process_FEFO_RiskInventory" name="Ablaufende oder riskante Lagerbestände priorisiert verbrauchen" isExecutable="false">
    <bpmn:documentation>
      Fachlicher Zweck: Wirtschaftliche Verluste vermeiden, indem ablaufende oder riskante Ressourcen frühzeitig erkannt,
      nach FEFO priorisiert und anschließend verbraucht, umgelagert oder ersetzt/entsorgt werden.
      Bezug zum Mars-Colony-Projekt: WebApp/PHP-API/SQL-Abfragen, insbesondere getRessourcesAtRisk.sql.
    </bpmn:documentation>
    <bpmn:laneSet id="LaneSet_FEFO">
      <bpmn:lane id="Lane_ProcurementDisposal" name="Einkauf / Recycling / Entsorgung">
        <bpmn:flowNodeRef>Task_ReplaceRecycleDispose</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PlanReplacementDisposal</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Logistics" name="Logistik / Transport">
        <bpmn:flowNodeRef>Task_PlanRelocation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1ja172q</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RelocateStock</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Production" name="Verbrauchseinheit / Produktion">
        <bpmn:flowNodeRef>Task_ConsumeStock</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Disposition" name="Lagerleitung / Disposition">
        <bpmn:flowNodeRef>Task_ReviewPriorityList</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ApproveConsumption</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SelectMeasure</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System" name="WebApp / Datenbank">
        <bpmn:flowNodeRef>StartEvent_DailyCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckAccess</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AccessValid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LogAccessError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_QueryRiskResources</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RiskResourcesFound</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LogNoRisk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_NoRisk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MeasureDone</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CalculateFEFO</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_RiskReduced</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UpdateInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_AccessError</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_DailyCheck" name="Tägliche Lagerprüfung">
      <bpmn:outgoing>Flow_Start_To_CheckAccess</bpmn:outgoing>
      <bpmn:timerEventDefinition id="Timer_DailyCheck" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CheckAccess" name="API-Zugriff und&#10;CSRF-Token prüfen">
      <bpmn:incoming>Flow_Start_To_CheckAccess</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckAccess_To_AccessValid</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_AccessValid" name="Zugriff gültig?">
      <bpmn:incoming>Flow_CheckAccess_To_AccessValid</bpmn:incoming>
      <bpmn:outgoing>Flow_AccessValid_No_To_LogAccessError</bpmn:outgoing>
      <bpmn:outgoing>Flow_AccessValid_Yes_To_QueryRiskResources</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_LogAccessError" name="Fehler protokollieren&#10;und Benutzer informieren">
      <bpmn:incoming>Flow_AccessValid_No_To_LogAccessError</bpmn:incoming>
      <bpmn:outgoing>Flow_LogAccessError_To_AccessError</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_QueryRiskResources" name="Riskante Ressourcen abfragen&#10;getRessourcesAtRisk.sql">
      <bpmn:incoming>Flow_AccessValid_Yes_To_QueryRiskResources</bpmn:incoming>
      <bpmn:outgoing>Flow_QueryRiskResources_To_RiskResourcesFound</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_RiskResourcesFound" name="Riskante Bestände vorhanden?">
      <bpmn:incoming>Flow_QueryRiskResources_To_RiskResourcesFound</bpmn:incoming>
      <bpmn:outgoing>Flow_RiskResourcesFound_No_To_LogNoRisk</bpmn:outgoing>
      <bpmn:outgoing>Flow_RiskResourcesFound_Yes_To_CalculateFEFO</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_LogNoRisk" name="Prüfung protokollieren&#10;keine Maßnahme nötig">
      <bpmn:incoming>Flow_RiskResourcesFound_No_To_LogNoRisk</bpmn:incoming>
      <bpmn:outgoing>Flow_LogNoRisk_To_NoRisk</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_NoRisk" name="Kein Risiko erkannt">
      <bpmn:incoming>Flow_LogNoRisk_To_NoRisk</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Task_ReviewPriorityList" name="Prioritätsliste prüfen&#10;und Maßnahme freigeben">
      <bpmn:incoming>Flow_CalculateFEFO_To_ReviewPriorityList</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewPriorityList_To_SelectMeasure</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_MeasureDone" name="Maßnahme abgeschlossen">
      <bpmn:incoming>Flow_ConsumeStock_To_MeasureDone</bpmn:incoming>
      <bpmn:incoming>Flow_RelocateStock_To_MeasureDone</bpmn:incoming>
      <bpmn:incoming>Flow_ReplaceRecycleDispose_To_MeasureDone</bpmn:incoming>
      <bpmn:outgoing>Flow_MeasureDone_To_UpdateInventory</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:businessRuleTask id="Task_CalculateFEFO" name="Priorität berechnen&#10;Ablaufdatum, Menge, Standort, Bedarf">
      <bpmn:incoming>Flow_RiskResourcesFound_Yes_To_CalculateFEFO</bpmn:incoming>
      <bpmn:outgoing>Flow_CalculateFEFO_To_ReviewPriorityList</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:userTask id="Task_PlanRelocation" name="Umlagerung planen&#10;Ziel-Lager / Stadt wählen">
      <bpmn:incoming>Flow_SelectMeasure_To_PlanRelocation</bpmn:incoming>
      <bpmn:outgoing>Flow_0skk5tf</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_1ja172q" name="Umlagerung möglich?">
      <bpmn:incoming>Flow_0skk5tf</bpmn:incoming>
      <bpmn:outgoing>Flow_144mabz</bpmn:outgoing>
      <bpmn:outgoing>Flow_0f3n6df</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:manualTask id="Task_RelocateStock" name="Bestand umlagern&#10;Transport durchführen">
      <bpmn:incoming>Flow_0f3n6df</bpmn:incoming>
      <bpmn:outgoing>Flow_RelocateStock_To_MeasureDone</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="Task_ReplaceRecycleDispose" name="Ersatz bestellen oder&#10;Bestand recyceln / entsorgen">
      <bpmn:incoming>Flow_PlanReplacementDisposal_To_ReplaceRecycleDispose</bpmn:incoming>
      <bpmn:outgoing>Flow_ReplaceRecycleDispose_To_MeasureDone</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:manualTask id="Task_ConsumeStock" name="Bestand priorisiert verbrauchen&#10;älteste Charge zuerst">
      <bpmn:incoming>Flow_ApproveConsumption_To_ConsumeStock</bpmn:incoming>
      <bpmn:outgoing>Flow_ConsumeStock_To_MeasureDone</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:endEvent id="EndEvent_RiskReduced" name="Verlustrisiko reduziert">
      <bpmn:incoming>Flow_UpdateInventory_To_RiskReduced</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_UpdateInventory" name="Bestand und Dashboard aktualisieren">
      <bpmn:incoming>Flow_MeasureDone_To_UpdateInventory</bpmn:incoming>
      <bpmn:outgoing>Flow_UpdateInventory_To_RiskReduced</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_AccessError" name="Prüfung abgebrochen">
      <bpmn:incoming>Flow_LogAccessError_To_AccessError</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Task_PlanReplacementDisposal" name="Ersatz / Recycling /&#10;Entsorgung planen">
      <bpmn:incoming>Flow_SelectMeasure_To_PlanReplacementDisposal</bpmn:incoming>
      <bpmn:incoming>Flow_144mabz</bpmn:incoming>
      <bpmn:outgoing>Flow_PlanReplacementDisposal_To_ReplaceRecycleDispose</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ApproveConsumption" name="Verbrauchsauftrag freigeben">
      <bpmn:incoming>Flow_SelectMeasure_To_ApproveConsumption</bpmn:incoming>
      <bpmn:outgoing>Flow_ApproveConsumption_To_ConsumeStock</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_SelectMeasure" name="Welche Maßnahme?">
      <bpmn:incoming>Flow_ReviewPriorityList_To_SelectMeasure</bpmn:incoming>
      <bpmn:outgoing>Flow_SelectMeasure_To_ApproveConsumption</bpmn:outgoing>
      <bpmn:outgoing>Flow_SelectMeasure_To_PlanRelocation</bpmn:outgoing>
      <bpmn:outgoing>Flow_SelectMeasure_To_PlanReplacementDisposal</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_Start_To_CheckAccess" sourceRef="StartEvent_DailyCheck" targetRef="Task_CheckAccess" />
    <bpmn:sequenceFlow id="Flow_CheckAccess_To_AccessValid" sourceRef="Task_CheckAccess" targetRef="Gateway_AccessValid" />
    <bpmn:sequenceFlow id="Flow_AccessValid_No_To_LogAccessError" name="Nein" sourceRef="Gateway_AccessValid" targetRef="Task_LogAccessError" />
    <bpmn:sequenceFlow id="Flow_AccessValid_Yes_To_QueryRiskResources" name="Ja" sourceRef="Gateway_AccessValid" targetRef="Task_QueryRiskResources" />
    <bpmn:sequenceFlow id="Flow_LogAccessError_To_AccessError" sourceRef="Task_LogAccessError" targetRef="EndEvent_AccessError" />
    <bpmn:sequenceFlow id="Flow_QueryRiskResources_To_RiskResourcesFound" sourceRef="Task_QueryRiskResources" targetRef="Gateway_RiskResourcesFound" />
    <bpmn:sequenceFlow id="Flow_RiskResourcesFound_No_To_LogNoRisk" name="Nein" sourceRef="Gateway_RiskResourcesFound" targetRef="Task_LogNoRisk" />
    <bpmn:sequenceFlow id="Flow_RiskResourcesFound_Yes_To_CalculateFEFO" name="Ja" sourceRef="Gateway_RiskResourcesFound" targetRef="Task_CalculateFEFO" />
    <bpmn:sequenceFlow id="Flow_LogNoRisk_To_NoRisk" sourceRef="Task_LogNoRisk" targetRef="EndEvent_NoRisk" />
    <bpmn:sequenceFlow id="Flow_CalculateFEFO_To_ReviewPriorityList" sourceRef="Task_CalculateFEFO" targetRef="Task_ReviewPriorityList" />
    <bpmn:sequenceFlow id="Flow_ReviewPriorityList_To_SelectMeasure" sourceRef="Task_ReviewPriorityList" targetRef="Gateway_SelectMeasure" />
    <bpmn:sequenceFlow id="Flow_ConsumeStock_To_MeasureDone" sourceRef="Task_ConsumeStock" targetRef="Gateway_MeasureDone" />
    <bpmn:sequenceFlow id="Flow_RelocateStock_To_MeasureDone" sourceRef="Task_RelocateStock" targetRef="Gateway_MeasureDone" />
    <bpmn:sequenceFlow id="Flow_ReplaceRecycleDispose_To_MeasureDone" sourceRef="Task_ReplaceRecycleDispose" targetRef="Gateway_MeasureDone" />
    <bpmn:sequenceFlow id="Flow_MeasureDone_To_UpdateInventory" sourceRef="Gateway_MeasureDone" targetRef="Task_UpdateInventory" />
    <bpmn:sequenceFlow id="Flow_SelectMeasure_To_PlanRelocation" name="Umlagern" sourceRef="Gateway_SelectMeasure" targetRef="Task_PlanRelocation" />
    <bpmn:sequenceFlow id="Flow_0skk5tf" sourceRef="Task_PlanRelocation" targetRef="Gateway_1ja172q" />
    <bpmn:sequenceFlow id="Flow_144mabz" name="Nein" sourceRef="Gateway_1ja172q" targetRef="Task_PlanReplacementDisposal" />
    <bpmn:sequenceFlow id="Flow_0f3n6df" name="Ja" sourceRef="Gateway_1ja172q" targetRef="Task_RelocateStock" />
    <bpmn:sequenceFlow id="Flow_PlanReplacementDisposal_To_ReplaceRecycleDispose" sourceRef="Task_PlanReplacementDisposal" targetRef="Task_ReplaceRecycleDispose" />
    <bpmn:sequenceFlow id="Flow_ApproveConsumption_To_ConsumeStock" sourceRef="Task_ApproveConsumption" targetRef="Task_ConsumeStock" />
    <bpmn:sequenceFlow id="Flow_UpdateInventory_To_RiskReduced" sourceRef="Task_UpdateInventory" targetRef="EndEvent_RiskReduced" />
    <bpmn:sequenceFlow id="Flow_SelectMeasure_To_PlanReplacementDisposal" name="Ersetzen / entsorgen" sourceRef="Gateway_SelectMeasure" targetRef="Task_PlanReplacementDisposal" />
    <bpmn:sequenceFlow id="Flow_SelectMeasure_To_ApproveConsumption" name="Verbrauchen" sourceRef="Gateway_SelectMeasure" targetRef="Task_ApproveConsumption" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_MarsColony_FEFO">
    <bpmndi:BPMNPlane id="BPMNPlane_MarsColony_FEFO" bpmnElement="Collaboration_MarsColony_FEFO">
